flowchart TB

    subgraph S1["① SVG Import (vite-plugin-svgr)"]
        direction LR
        F1["HomeIcon.svg"]    -->|"?react"| C1["&lt;HomeIcon /&gt;"]
        F2["ExploreIcon.svg"] -->|"?react"| C2["&lt;ExploreIcon /&gt;"]
        F3["CreateIcon.svg"]  -->|"?react"| C3["&lt;CreateIcon /&gt;"]
        F4["ChatIcon.svg"]    -->|"?react"| C4["&lt;ChatIcon /&gt;"]
        F5["BellIcon.svg"]    -->|"?react"| C5["&lt;BellIcon /&gt;"]
    end

    subgraph S2["② navItems 배열 (데이터)"]
        ARR["const navItems = [ ... ]"]
        ARR --> NI1["[0] home\nactive: true\nIcon: HomeIcon"]
        ARR --> NI2["[1] explore\nactive: false\nIcon: ExploreIcon"]
        ARR --> NI3["[2] create\nactive: false\nIcon: CreateIcon"]
        ARR --> NI4["[3] chat\nactive: false\nIcon: ChatIcon\nhasBadge: true"]
    end

    subgraph S3["③ 렌더링 로직 (JSX)"]
        MAP["navItems.map((item) =&gt; JSX)"]
        MAP --> ITER["각 item마다 div 블록 생성"]
        ITER --> COND1{"item.active ?"}
        COND1 -->|"true"| ACT["'--active' 클래스 추가\n핑크 배경 + 붉은 글자"]
        COND1 -->|"false"| NACT["기본 스타일 유지"]
        ITER --> COND2{"item.hasBadge ?"}
        COND2 -->|"true"| BADGE["&lt;div.header_nav-badge /&gt; 렌더\n빨간 점 표시"]
        COND2 -->|"false"| NBADGE["null 반환\n(아무것도 렌더 안 함)"]
    end

    subgraph S4["④ DOM 트리 결과"]
        H["&lt;header&gt; .header"]
        H --> HC["&lt;div&gt; .header_container\ndisplay:flex / justify:flex-start"]
        HC --> HL["&lt;div&gt; .header_logo"]
        HC --> HN["&lt;nav&gt; .header_nav\nmargin-left: 550px"]
        HC --> HRGT["&lt;div&gt; .header_right\nmargin-left: auto"]
        HL --> IMG["&lt;img&gt; /logo.png\nobject-fit: contain"]
        HN --> NAVMAP["map() 결과 × 4\n(Home / Explore / Create / Chat)"]
        HRGT --> BELL["&lt;div&gt; .header_bell\nposition: relative"]
        HRGT --> PROF["&lt;div&gt; .header_profile\nborder-radius: 50%"]
        BELL --> BI["&lt;BellIcon /&gt; SVG"]
        BELL --> BB["&lt;div&gt; .header_bell-badge\n빨간 점"]
    end

    %% 섹션 간 연결
    ARR  -->|"데이터 전달"| MAP
    C1   -->|"Icon 속성 주입"| NI1
    C2   -->|"Icon 속성 주입"| NI2
    C3   -->|"Icon 속성 주입"| NI3
    C4   -->|"Icon 속성 주입"| NI4
    MAP  -->|"렌더링 출력"| NAVMAP
    C5   -->|"직접 사용"| BI

    %% 스타일
    style S1 fill:#f3e8ff,stroke:#9673a6
    style S2 fill:#fff8e1,stroke:#d6b656
    style S3 fill:#fff0f0,stroke:#b85450
    style S4 fill:#e8f4fd,stroke:#6c8ebf

    style F1 fill:#e1d5e7,stroke:#9673a6
    style F2 fill:#e1d5e7,stroke:#9673a6
    style F3 fill:#e1d5e7,stroke:#9673a6
    style F4 fill:#e1d5e7,stroke:#9673a6
    style F5 fill:#e1d5e7,stroke:#9673a6

    style C1 fill:#dae8fc,stroke:#6c8ebf
    style C2 fill:#dae8fc,stroke:#6c8ebf
    style C3 fill:#dae8fc,stroke:#6c8ebf
    style C4 fill:#dae8fc,stroke:#6c8ebf
    style C5 fill:#dae8fc,stroke:#6c8ebf

    style NI1 fill:#d5e8d4,stroke:#82b366
    style NI2 fill:#fff2cc,stroke:#d6b656
    style NI3 fill:#fff2cc,stroke:#d6b656
    style NI4 fill:#f8cecc,stroke:#b85450

    style COND1 fill:#fff2cc,stroke:#d6b656
    style COND2 fill:#fff2cc,stroke:#d6b656
    style ACT   fill:#d5e8d4,stroke:#82b366
    style BADGE fill:#f8cecc,stroke:#b85450
